# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=salaah_db
DB_USER=salaah_user
DB_PASS=changeme

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# App
APP_URL=https://api.yourdomain.com
APP_NAME=Salaah Times
APP_ENV=production

# SMTP
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@yourdomain.com
SMTP_PASSWORD=changeme
SMTP_SECURE=ssl
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Salaah Times

# Facebook OAuth (optional)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# Firebase (for FCM push notifications)
FIREBASE_PROJECT_ID=102097759868336342332
FIREBASE_SERVICE_ACCOUNT_JSON=./secrets/firebase-service-account.json

# CORS
CORS_ALLOWED_ORIGINS=*
