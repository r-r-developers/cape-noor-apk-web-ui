{"surah":{"number":1,"name":"سُورَةُ ٱلْفَاتِحَةِ","englishName":"Al-Faatiha","englishNameTranslation":"The Opening","numberOfAyahs":7,"revelationType":"Meccan"},"ayahs":[{"number":1,"numberInSurah":1,"text":"﻿بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ","translation":"In the name of God, The Most Gracious, The Dispenser of Grace:","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/1.mp3","page":1,"juz":1},{"number":2,"numberInSurah":2,"text":"الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ","translation":"All praise is due to God alone, the Sustainer of all the worlds,","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/2.mp3","page":1,"juz":1},{"number":3,"numberInSurah":3,"text":"الرَّحْمَٰنِ الرَّحِيمِ","translation":"The Most Gracious, the Dispenser of Grace,","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/3.mp3","page":1,"juz":1},{"number":4,"numberInSurah":4,"text":"مَالِكِ يَوْمِ الدِّينِ","translation":"Lord of the Day of Judgment!","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/4.mp3","page":1,"juz":1},{"number":5,"numberInSurah":5,"text":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","translation":"Thee alone do we worship; and unto Thee alone do we turn for aid.","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/5.mp3","page":1,"juz":1},{"number":6,"numberInSurah":6,"text":"اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ","translation":"Guide us the straight way.","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/6.mp3","page":1,"juz":1},{"number":7,"numberInSurah":7,"text":"صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ","translation":"The way of those upon whom Thou hast bestowed Thy blessings, not of those who have been condemned [by Thee], nor of those who go astray!","audio":"https:\/\/cdn.islamic.network\/quran\/audio\/128\/ar.alafasy\/7.mp3","page":1,"juz":1}]}