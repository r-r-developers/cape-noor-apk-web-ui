{
    "name": "salaah/api",
    "description": "Salaah App REST API v2 — Slim 4",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "firebase/php-jwt": "*",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.7",
        "respect/validation": "^2.3",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
